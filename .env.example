# NoteWeaver Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# === LLM Provider (set at least one) ===
OPENAI_API_KEY=sk-your-openai-key
# OpenAI-compatible gateway (vLLM, LiteLLM, etc.): use one of:
# OPENAI_BASE_URL=https://api.example.com/v1
# OPENAI_API_BASE=https://api.example.com/v1
# ANTHROPIC_API_KEY=
# Custom Claude / Anthropic endpoint: use one of:
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_API_URL=
# CLAUDE_API_URL=

# Optional: force provider or model
# NW_PROVIDER=openai
# NW_MODEL=gpt-4o

# === Telegram Bot ===
NW_TELEGRAM_TOKEN=your-telegram-bot-token

# Optional: restrict access to specific user IDs (comma-separated)
# NW_TELEGRAM_ALLOWED_USERS=123456789

# === Cron Intervals ===
NW_DIGEST_INTERVAL_HOURS=6
NW_LINT_INTERVAL_HOURS=24
# NW_NOTIFY_HOUR=9
