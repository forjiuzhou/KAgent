# NoteWeaver Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# === LLM Provider (set at least one) ===
OPENAI_API_KEY=sk-your-openai-key
# OPENAI_BASE_URL=
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=

# Optional: force provider or model
# NW_PROVIDER=openai
# NW_MODEL=gpt-4o

# === Telegram Bot ===
NW_TELEGRAM_TOKEN=your-telegram-bot-token

# Optional: restrict access to specific user IDs (comma-separated)
# NW_TELEGRAM_ALLOWED_USERS=123456789

# === Cron Intervals ===
NW_DIGEST_INTERVAL_HOURS=6
NW_LINT_INTERVAL_HOURS=24
